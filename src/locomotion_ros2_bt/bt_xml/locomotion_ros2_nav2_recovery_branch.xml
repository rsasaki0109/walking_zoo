<root BTCPP_format="4" main_tree_to_execute="WalkingRecoveryBranch">
  <!--
    The locomotion_ros2 recovery branch, isolated exactly as it is embedded inside the
    Nav2 navigate-to-pose recovery subtree (see
    navigate_to_pose_w_walking_recovery.xml). It is loaded through the real
    nav2_behavior_tree::BehaviorTreeEngine with
    plugin_lib_names = {locomotion_ros2_nav2_bt_nodes}.

    If the robot is already ready, IsWalkingReady succeeds and the branch is a
    no-op. Otherwise ClearWalkingFault calls /locomotion_ros2/clear_fault and the
    trailing IsWalkingReady re-checks the refreshed state, so the branch only
    reports SUCCESS once the robot is genuinely ready again.
  -->
  <BehaviorTree ID="WalkingRecoveryBranch">
    <Sequence name="WalkingFaultRecovery">
      <Fallback name="ReadyOrClear">
        <IsWalkingReady state_topic="/locomotion_ros2/state"/>
        <ClearWalkingFault service_name="/locomotion_ros2/clear_fault" reason="nav2_bt_recovery"/>
      </Fallback>
      <IsWalkingReady state_topic="/locomotion_ros2/state"/>
    </Sequence>
  </BehaviorTree>
</root>
