<root BTCPP_format="4" main_tree_to_execute="LocomotionRos2RecoveryLive">
  <!--
    Live recovery tree driven by locomotion_ros2_bt_recovery_node. The node refreshes
    the `walking_state` blackboard entry from /locomotion_ros2/state before each tick.
    Unlike the port-only recovery tree, ClearWalkingFaultService here actually
    calls the /locomotion_ros2/clear_fault service and only reports SUCCESS when the
    runtime confirms the fault is cleared, after which readiness is re-checked on
    the next refreshed state.
  -->
  <BehaviorTree ID="LocomotionRos2RecoveryLive">
    <Fallback name="locomotion_ros2_recovery_live">
      <CheckWalkingReady walking_state="{walking_state}"/>
      <ClearWalkingFaultService reason="bt_recovery" status_text="{clear_status}"/>
    </Fallback>
  </BehaviorTree>
</root>
